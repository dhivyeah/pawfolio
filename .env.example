# Copy this file to .env (same folder) and fill in your real values.
# .env is already gitignored — it will never be committed.

# Your Supabase project's public API URL and anon key (Project Settings -> API in the
# Supabase dashboard). Used for Supabase Auth (login/signup) and Storage (photos) --
# never the service_role key, which must never be used by this app.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# Where a password-reset email's link sends the browser back to. Must be on the
# project's Redirect URLs allow-list (Authentication -> URL Configuration in the
# Supabase dashboard) or the reset link will fall back to Supabase's default instead.
# Defaults to the deployed app if unset.
APP_URL=https://mypawfolio.streamlit.app

# Your Resend API key. Get one at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Notification emails now go to each logged-in user's own account email (Phase 4) --
# NOTIFY_EMAIL is no longer read anywhere and can be left unset.

# Optional. The "From" address Resend sends as. The default below
# (onboarding@resend.dev) works out of the box with no setup, but Resend
# only allows it to send to the email address on your own Resend account.
# Once you verify your own domain in Resend, put a real address on that
# domain here to send to any recipient.
RESEND_FROM_EMAIL=Pawfolio <onboarding@resend.dev>

# Your Supabase Postgres connection string. In the Supabase dashboard:
# Project Settings -> Database -> Connection string -> "Transaction" pooler
# mode (port 6543), NOT the direct connection (port 5432) -- the pooler is
# built for lots of short-lived connections, which is exactly what a
# Streamlit app opening a fresh connection per session looks like. Copy the
# URI form and swap in your actual database password.
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-your-region.pooler.supabase.com:6543/postgres
